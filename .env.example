# =============================================
# Dashboard Logística Loggi - Configurações
# =============================================

# Ambiente (development, production)
DASH_ENV=development

# Servidor
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=true

# Mapbox API Token (opcional - para mapas avançados)
# Obtenha em: https://account.mapbox.com/
MAPBOX_TOKEN=

# Cache (Redis ou disco)
CACHE_TYPE=diskcache
# CACHE_TYPE=redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Segurança
SECRET_KEY=sua-secret-key-aqui-mude-em-producao

# Dados
DATA_SOURCE=local
# DATA_SOURCE=api
DATA_API_URL=https://api.example.com/data